  <!-- Segment Switcher Script -->
  <script>
    // B2B/B2C segment switching
    const segmentB2bBtn = document.getElementById('segment-b2b');
    const segmentB2cBtn = document.getElementById('segment-b2c');
    const servicesB2bBtn = document.getElementById('services-b2b');
    const servicesB2cBtn = document.getElementById('services-b2c');
    const b2bContent = document.querySelectorAll('.b2b-content');
    const b2cContent = document.querySelectorAll('.b2c-content');
    const servicesB2bGrid = document.getElementById('services-b2b-grid');
    const servicesB2cGrid = document.getElementById('services-b2c-grid');
    
    function setSegment(segment) {
      localStorage.setItem('segment', segment);
      
      if (segment === 'b2b') {
        // Hero buttons
        segmentB2bBtn.classList.add('bg-[var(--primary)]', 'text-white');
        segmentB2bBtn.classList.remove('text-[var(--text-secondary)]');
        segmentB2cBtn.classList.remove('bg-[var(--primary)]', 'text-white');
        segmentB2cBtn.classList.add('text-[var(--text-secondary)]');
        
        // Services buttons
        servicesB2bBtn.classList.add('bg-[var(--primary)]', 'text-white');
        servicesB2bBtn.classList.remove('text-[var(--text-secondary)]');
        servicesB2cBtn.classList.remove('bg-[var(--primary)]', 'text-white');
        servicesB2cBtn.classList.add('text-[var(--text-secondary)]');
        
        // Content visibility
        b2bContent.forEach(el => el.classList.remove('hidden'));
        b2cContent.forEach(el => el.classList.add('hidden'));
        servicesB2bGrid.classList.remove('hidden');
        servicesB2cGrid.classList.add('hidden');
      } else {
        // Hero buttons
        segmentB2cBtn.classList.add('bg-[var(--primary)]', 'text-white');
        segmentB2cBtn.classList.remove('text-[var(--text-secondary)]');
        segmentB2bBtn.classList.remove('bg-[var(--primary)]', 'text-white');
        segmentB2bBtn.classList.add('text-[var(--text-secondary)]');
        
        // Services buttons
        servicesB2cBtn.classList.add('bg-[var(--primary)]', 'text-white');
        servicesB2cBtn.classList.remove('text-[var(--text-secondary)]');
        servicesB2bBtn.classList.remove('bg-[var(--primary)]', 'text-white');
        servicesB2bBtn.classList.add('text-[var(--text-secondary)]');
        
        // Content visibility
        b2cContent.forEach(el => el.classList.remove('hidden'));
        b2bContent.forEach(el => el.classList.add('hidden'));
        servicesB2cGrid.classList.remove('hidden');
        servicesB2bGrid.classList.add('hidden');
      }
    }
    
    // Initialize from URL params or localStorage
    const urlParams = new URLSearchParams(window.location.search);
    const urlSegment = urlParams.get('segment');
    const storedSegment = localStorage.getItem('segment');
    const initialSegment = urlSegment || storedSegment || 'b2b';
    
    setSegment(initialSegment);
    
    // Event listeners
    segmentB2bBtn.addEventListener('click', () => setSegment('b2b'));
    segmentB2cBtn.addEventListener('click', () => setSegment('b2c'));
    servicesB2bBtn.addEventListener('click', () => setSegment('b2b'));
    servicesB2cBtn.addEventListener('click', () => setSegment('b2c'));
    
    // Phone mask (simple implementation)
    const phoneInput = document.getElementById('phone');
    if (phoneInput) {
      phoneInput.addEventListener('input', (e) => {
        let value = e.target.value.replace(/\D/g, '');
        if (value.startsWith('7')) {
          value = value.substring(1);
        }
        if (value.length > 10) {
          value = value.substring(0, 10);
        }
        
        let formatted = '+7';
        if (value.length > 0) {
          formatted += ' (' + value.substring(0, 3);
        }
        if (value.length > 3) {
          formatted += ') ' + value.substring(3, 6);
        }
        if (value.length > 6) {
          formatted += '-' + value.substring(6, 8);
        }
        if (value.length > 8) {
          formatted += '-' + value.substring(8, 10);
        }
        
        e.target.value = formatted;
      });
    }
    
    // Form submission
    const form = document.getElementById('contact-form');
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        
        // Client-side validation
        if (!data.name || !data.phone || !data.segment || !data.consent) {
          alert('Пожалуйста, заполните все обязательные поля');
          return;
        }
        
        // Send analytics event
        console.log('form_submit', data);
        
        // Submit to API (placeholder)
        try {
          const response = await fetch('/api/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });
          
          if (response.ok) {
            alert('Спасибо! Ваша заявка отправлена. Мы перезвоним вам в ближайшее время.');
            form.reset();
          } else {
            throw new Error('Failed to submit');
          }
        } catch (error) {
          console.error('Form submission error:', error);
          alert('Произошла ошибка при отправке. Пожалуйста, позвоните нам напрямую.');
        }
      });
    }
  </script>
