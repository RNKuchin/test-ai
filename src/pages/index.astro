  },
];
---

<HomeLayout title="Proholod72 - Ремонт холодильного оборудования в Тюмени">
  <!-- Header -->
  <header class="sticky top-0 bg-white/95 backdrop-blur-sm shadow-sm z-40">
    <div class="container-custom">
      <nav class="flex items-center justify-between py-4">
        <!-- Logo -->
        <a href="/" class="flex items-center space-x-2">
          <div class="w-10 h-10 bg-[var(--primary)] rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-xl">P72</span>
          </div>
          <div class="hidden sm:block">
            <span class="block font-bold text-lg text-[var(--text-primary)]">Proholod72</span>
            <span class="block text-xs text-[var(--text-secondary)]">Boreal Klimat</span>
          </div>
        </a>
        
        <!-- Desktop Navigation -->
        <div class="hidden lg:flex items-center space-x-6">
          {NAV_LINKS.map((link) => (
            <a href={link.href} class="text-[var(--text-secondary)] hover:text-[var(--primary)] transition-colors font-medium">
              {link.name}
            </a>
          ))}
        </div>
        
        <!-- Contact & CTA -->
        <div class="flex items-center space-x-4">
          <a href={CONTACTS.phoneHref} class="hidden md:block text-[var(--text-primary)] font-semibold hover:text-[var(--primary)] transition-colors">
            {CONTACTS.phone}
          </a>
          <button class="btn-primary hidden sm:block">
            Заказать звонок
          </button>
          <!-- Mobile menu button -->
          <button class="lg:hidden p-2" aria-label="Меню">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </nav>
    </div>
  </header>

  <!-- Hero Section -->
  <section id="hero" class="section-padding bg-gradient-to-br from-[var(--bg-secondary)] to-white">
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <!-- B2B/B2C Toggle -->
          <div class="inline-flex bg-white rounded-lg p-1 shadow-md mb-6">
            <button id="segment-b2b" class="px-4 py-2 rounded-md font-medium bg-[var(--primary)] text-white transition-all">
              Для бизнеса
            </button>
            <button id="segment-b2c" class="px-4 py-2 rounded-md font-medium text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-all">
              Частным лицам
            </button>
          </div>
          
          <h1 class="mb-4">
            <span class="b2b-content">Профессиональное обслуживание холодильного оборудования для бизнеса</span>
            <span class="b2c-content hidden">Быстрый ремонт холодильников и кондиционеров на дому</span>
          </h1>
          
          <p class="text-lg text-[var(--text-secondary)] mb-8">
            <span class="b2b-content">Работаем с ресторанами, магазинами и бюджетными учреждениями. Выезд в день обращения, полный пакет документов.</span>
            <span class="b2c-content hidden">Честные цены, мастер с запчастями, оплата после проверки работы. Гарантия до 12 месяцев.</span>
          </p>
          
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#contact" class="btn-primary text-center">
              Оставить заявку
            </a>
            <a href={CONTACTS.phoneHref} class="btn-secondary text-center">
              {CONTACTS.phone}
            </a>
          </div>
          
          <!-- Trust badges -->
          <div class="mt-8 flex items-center space-x-6 text-sm text-[var(--text-secondary)]">
            <div class="flex items-center space-x-2">
              <span class="text-[var(--accent)]">✓</span>
              <span>Гарантия до 12 мес</span>
            </div>
            <div class="flex items-center space-x-2">
              <span class="text-[var(--accent)]">✓</span>
              <span>Выезд за 2 часа</span>
            </div>
          </div>
        </div>
        
        <!-- Hero Image Placeholder -->
        <div class="relative">
          <div class="aspect-square bg-gradient-to-br from-[var(--primary)] to-[var(--accent)] rounded-2xl shadow-2xl flex items-center justify-center">
            <div class="text-center text-white p-8">
              <div class="text-6xl mb-4">❄️</div>
              <p class="text-xl font-semibold">Фото техника за работой</p>
              <p class="text-sm opacity-80 mt-2">(плейсхолдер)</p>
            </div>
          </div>
          
          <!-- Floating badge -->
          <div class="absolute -bottom-4 -left-4 bg-white rounded-xl shadow-lg p-4">
            <div class="flex items-center space-x-3">
              <div class="text-3xl">⭐</div>
              <div>
                <div class="font-bold text-[var(--text-primary)]">4.9/5</div>
                <div class="text-xs text-[var(--text-secondary)]">рейтинг в 2ГИС</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof Section -->
  <section id="clients" class="section-padding bg-white">
    <div class="container-custom">
      <h2 class="text-center mb-12">Нам доверяют</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {CLIENTS.map((client) => (
          <div class="flex flex-col items-center p-6 rounded-xl bg-[var(--bg-secondary)] hover:shadow-md transition-shadow">
            <div class="w-24 h-24 bg-gray-200 rounded-lg flex items-center justify-center mb-4">
              <span class="text-4xl">🏢</span>
            </div>
            <span class="text-center font-medium text-[var(--text-primary)]">{client.name}</span>
          </div>
        ))}
      </div>
      
      <!-- Reviews placeholder -->
      <div class="mt-12 text-center">
        <p class="text-[var(--text-secondary)] mb-4">Отзывы наших клиентов</p>
        <div class="flex justify-center items-center space-x-4">
          <div class="flex items-center space-x-2">
            <span class="text-yellow-400">★★★★★</span>
            <span class="font-medium">2ГИС</span>
          </div>
          <div class="flex items-center space-x-2">
            <span class="text-yellow-400">★★★★★</span>
            <span class="font-medium">Яндекс.Карты</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Advantages Section -->
  <section id="advantages" class="section-padding bg-[var(--bg-secondary)]">
    <div class="container-custom">
      <h2 class="text-center mb-12">Почему выбирают нас</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {ADVANTAGES.map((advantage) => (
          <div class="card">
            <div class="text-4xl mb-4">{advantage.icon}</div>
            <h3 class="text-xl mb-2">{advantage.title}</h3>
            <p class="text-[var(--text-secondary)]">{advantage.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="section-padding bg-white">
    <div class="container-custom">
      <h2 class="text-center mb-8">Наши услуги</h2>
      
      <!-- Services Toggle -->
      <div class="flex justify-center mb-12">
        <div class="inline-flex bg-[var(--bg-secondary)] rounded-lg p-1">
          <button id="services-b2b" class="px-6 py-2 rounded-md font-medium bg-[var(--primary)] text-white transition-all">
            Для бизнеса
          </button>
          <button id="services-b2c" class="px-6 py-2 rounded-md font-medium text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-all">
            Частным лицам
          </button>
        </div>
      </div>
      
      <!-- B2B Services -->
      <div id="services-b2b-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {SERVICES_B2B.map((service) => (
          <div class="card border-2 border-transparent hover:border-[var(--primary)] transition-all">
            <h3 class="text-xl font-bold mb-2">{service.title}</h3>
            <p class="text-[var(--text-secondary)] mb-4">{service.description}</p>
            <div class="text-2xl font-bold text-[var(--primary)] mb-4">{service.price}</div>
            <ul class="space-y-2 mb-6">
              {service.features.map((feature) => (
                <li class="flex items-center space-x-2 text-sm">
                  <span class="text-[var(--accent)]">✓</span>
                  <span class="text-[var(--text-secondary)]">{feature}</span>
                </li>
              ))}
            </ul>
            <a href="#contact" class="btn-primary block text-center">Заказать</a>
          </div>
        ))}
      </div>
      
      <!-- B2C Services (hidden by default) -->
      <div id="services-b2c-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 hidden">
        {SERVICES_B2C.map((service) => (
          <div class="card border-2 border-transparent hover:border-[var(--primary)] transition-all">
            <h3 class="text-xl font-bold mb-2">{service.title}</h3>
            <p class="text-[var(--text-secondary)] mb-4">{service.description}</p>
            <div class="text-2xl font-bold text-[var(--primary)] mb-4">{service.price}</div>
            <ul class="space-y-2 mb-6">
              {service.features.map((feature) => (
                <li class="flex items-center space-x-2 text-sm">
                  <span class="text-[var(--accent)]">✓</span>
                  <span class="text-[var(--text-secondary)]">{feature}</span>
                </li>
              ))}
            </ul>
            <a href="#contact" class="btn-primary block text-center">Заказать</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section id="process" class="section-padding bg-gradient-to-br from-[var(--primary)] to-[var(--primary-dark)] text-white">
    <div class="container-custom">
      <h2 class="text-center mb-12">Как мы работаем</h2>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-8">
        {PROCESS_STEPS.map((step, index) => (
          <div class="text-center relative">
            <div class="w-16 h-16 mx-auto bg-white/20 rounded-full flex items-center justify-center mb-4 text-2xl font-bold">
              {step.step}
            </div>
            <h3 class="text-lg font-bold mb-2">{step.title}</h3>
            <p class="text-sm opacity-90">{step.description}</p>
            {index < PROCESS_STEPS.length - 1 && (
              <div class="hidden md:block absolute top-8 left-1/2 w-full h-0.5 bg-white/20"></div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section id="pricing" class="section-padding bg-white">
    <div class="container-custom">
      <h2 class="text-center mb-4">Тарифы на обслуживание</h2>
      <p class="text-center text-[var(--text-secondary)] mb-12 max-w-2xl mx-auto">
        Выберите подходящий тариф для вашего бизнеса или частного дома
      </p>
      
      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {PRICING_TIERS.map((tier) => (
          <div class={`card relative ${tier.popular ? 'border-2 border-[var(--primary)] scale-105' : ''}`}>
            {tier.popular && (
              <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 bg-[var(--accent)] text-white px-4 py-1 rounded-full text-sm font-semibold">
                Популярный
              </div>
            )}
            <h3 class="text-2xl font-bold mb-2">{tier.name}</h3>
            <div class="mb-6">
              <span class="text-4xl font-bold text-[var(--primary)]">{tier.price}</span>
              <span class="text-[var(--text-secondary)]"> {tier.period}</span>
            </div>
            <ul class="space-y-3 mb-8">
              {tier.features.map((feature) => (
                <li class="flex items-center space-x-3">
                  <span class="text-[var(--accent)] flex-shrink-0">✓</span>
                  <span class="text-[var(--text-secondary)]">{feature}</span>
                </li>
              ))}
            </ul>
            <a href="#contact" class={`block text-center ${tier.popular ? 'btn-primary' : 'btn-secondary'}`}>
              {tier.cta}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section id="faq" class="section-padding bg-[var(--bg-secondary)]">
    <div class="container-custom max-w-3xl">
      <h2 class="text-center mb-12">Частые вопросы</h2>
      
      <div class="space-y-4">
        {FAQ_ITEMS.map((item, index) => (
          <details class="card group" name="faq" aria-labelledby={`faq-${index}`}>
            <summary class="flex items-center justify-between cursor-pointer list-none">
              <h3 id={`faq-${index}`} class="text-lg font-semibold text-[var(--text-primary)] pr-8">
                {item.question}
              </h3>
              <span class="transform transition-transform group-open:rotate-180">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </span>
            </summary>
            <p class="mt-4 text-[var(--text-secondary)] leading-relaxed">
              {item.answer}
            </p>
          </details>
        ))}
      </div>
      
      <!-- FAQ Schema -->
      <script type="application/ld+json">
        {JSON.stringify({
          "@context": "https://schema.org",
          "@type": "FAQPage",
          "mainEntity": FAQ_ITEMS.map(item => ({
            "@type": "Question",
            "name": item.question,
            "acceptedAnswer": {
              "@type": "Answer",
              "text": item.answer
            }
          }))
        })}
      </script>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section id="contact" class="section-padding bg-white">
    <div class="container-custom max-w-2xl">
      <div class="text-center mb-12">
        <h2 class="mb-4">Оставьте заявку</h2>
        <p class="text-[var(--text-secondary)]">
          Перезвоним в течение 15 минут и ответим на все вопросы
        </p>
      </div>
      
      <form id="contact-form" class="card space-y-6" action="/api/submit" method="POST">
        <div>
          <label for="name" class="block text-sm font-medium text-[var(--text-primary)] mb-2">
            Ваше имя *
          </label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            required
            placeholder="Иван Иванов"
            class="input-field"
          />
        </div>
        
        <div>
          <label for="phone" class="block text-sm font-medium text-[var(--text-primary)] mb-2">
            Телефон *
          </label>
          <input 
            type="tel" 
            id="phone" 
            name="phone" 
            required
            placeholder="+7 (___) ___-__-__"
            class="input-field"
          />
        </div>
        
        <div>
          <label for="segment" class="block text-sm font-medium text-[var(--text-primary)] mb-2">
            Тип клиента *
          </label>
          <select id="segment" name="segment" required class="input-field">
            <option value="">Выберите тип</option>
            <option value="b2b">Юридическое лицо / ИП</option>
            <option value="b2c">Частное лицо</option>
          </select>
