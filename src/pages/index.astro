  phone: '+7 (982) 925-19-19',
  phoneHref: 'tel:+79829251919',
  email: 'prholod72@mail.ru',
  emailHref: 'mailto:prholod72@mail.ru',
  whatsapp: 'https://wa.me/79829251919',
  telegram: 'https://t.me/+79829251919',
