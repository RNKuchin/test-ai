  {
    title: 'Ремонт бытовых холодильников',
    description: 'Ремонт холодильников всех марок на дому или в мастерской',
    price: 'от 1 500 ₽',
    features: ['Бесплатная диагностика', 'Запчасти в наличии', 'Гарантия 6-12 мес'],
  },
  {
    title: 'Ремонт кондиционеров',
    description: 'Чистка, заправка, ремонт сплит-систем и мобильных кондиционеров',
    price: 'от 2 000 ₽',
    features: ['Выезд на дом', 'Честные цены', 'Оплата после проверки'],
  },
  {
    title: 'Установка и подключение',
    description: 'Подключение бытовой техники с гарантией качества',
    price: 'от 1 000 ₽',
    features: ['Аккуратная работа', 'Проверка после установки', 'Консультация'],
  },
];

const ADVANTAGES = [
  {
    icon: '🚐',
    title: 'Быстрый выезд',
    description: 'Выезд мастера в течение 2 часов или в удобное время',
  },
  {
    icon: '📄',
    title: 'Полный пакет документов',
    description: 'Работаем по договору, предоставляем акты и гарантии',
  },
  {
    icon: '💰',
    title: 'Честный прайс',
    description: 'Фиксируем цену до начала работ, без скрытых платежей',
  },
  {
    icon: '🛡️',
    title: 'Гарантия до 12 месяцев',
    description: 'Гарантия на все виды работ и установленные запчасти',
  },
  {
    icon: '⚙️',
    title: 'Запчасти в наличии',
    description: 'Собственный склад запчастей для популярных моделей',
  },
  {
    icon: '🏢',
    title: 'Опыт с госучреждениями',
    description: 'Работаем с детсадами, школами и бюджетными организациями',
  },
];

const PROCESS_STEPS = [
  { step: 1, title: 'Заявка', description: 'Оставляете заявку на сайте или по телефону' },
  { step: 2, title: 'Выезд', description: 'Мастер приезжает в согласованное время' },
  { step: 3, title: 'Диагностика', description: 'Бесплатная диагностика и оценка стоимости' },
  { step: 4, title: 'Ремонт', description: 'Выполняем ремонт с гарантией качества' },
  { step: 5, title: 'Оплата', description: 'Оплачиваете после проверки работы' },
];

const PRICING_TIERS = [
  {
    name: 'Базовый',
    price: 'от 1 500 ₽',
    period: 'за выезд',
    features: [
      'Диагностика оборудования',
      'Консультация специалиста',
      'Мелкий ремонт',
      'Гарантия 3 месяца',
    ],
    cta: 'Заказать',
    popular: false,
  },
  {
    name: 'Стандарт',
    price: 'от 5 000 ₽',
    period: 'в месяц',
    features: [
      'Всё из Базового',
      '2 плановых ТО в год',
      'Приоритетный выезд',
      'Скидка 10% на запчасти',
      'Гарантия 6 месяцев',
    ],
    cta: 'Популярный',
    popular: true,
  },
  {
    name: 'Премиум',
    price: 'от 15 000 ₽',
    period: 'в месяц',
    features: [
      'Всё из Стандарта',
      'Ежемесячные ТО',
      'Выезд 24/7',
      'Персональный менеджер',
      'Гарантия 12 месяцев',
    ],
    cta: 'Заказать',
    popular: false,
  },
];

const FAQ_ITEMS = [
  {
    question: 'Как быстро вы можете приехать?',
    answer: 'Обычно мы выезжаем в течение 2-4 часов после заявки. Для клиентов на абонентском обслуживании — приоритетный выезд в течение 1 часа.',
  },
  {
    question: 'Даёте ли вы гарантию на работы?',
    answer: 'Да, мы предоставляем гарантию от 3 до 12 месяцев в зависимости от типа работ. На некоторые виды абонентского обслуживания гарантия продлевается.',
  },
  {
    question: 'Работаете ли вы с юридическими лицами?',
    answer: 'Да, мы работаем с ИП и ООО. Предоставляем полный пакет документов: договор, акты выполненных работ, счета. Работаем с НДС и без.',
  },
  {
    question: 'Нужно ли платить за диагностику?',
    answer: 'При заказе ремонта диагностика бесплатна. Если вы отказываетесь от ремонта после диагностики, стоимость выезда составляет 500 ₽.',
  },
  {
    question: 'Какие марки оборудования вы обслуживаете?',
